# SentinelAI Environment Configuration
# Copy to .env and fill in values

# Application
APP_ENV=development
APP_NAME=SentinelAI
APP_VERSION=1.0.0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinelai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_METRICS=sentinel.metrics
KAFKA_TOPIC_LOGS=sentinel.logs
KAFKA_TOPIC_INCIDENTS=sentinel.incidents
KAFKA_TOPIC_ACTIONS=sentinel.actions
KAFKA_CONSUMER_GROUP=sentinel-workers

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=sentinelai-runbooks
PINECONE_DIMENSION=1536

# OpenAI / LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=120

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinelai-api
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# Auth
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# External integrations (optional in dev)
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
KUBERNETES_ENABLED=false
ECS_ENABLED=false

# Multi-tenant
DEFAULT_TENANT_ID=default
TENANT_ISOLATION_ENABLED=true
